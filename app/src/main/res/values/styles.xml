<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.AIStudyAssistance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.AIStudyAssistance.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.AIStudyAssistance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.AIStudyAssistance.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.AIStudyAssistance.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_m</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.AIStudyAssistance.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.AIStudyAssistance.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="strokeColor">@color/divider</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="Widget.AIStudyAssistance.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:padding">@dimen/space_16</item>
    </style>

    <style name="Widget.AIStudyAssistance.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/primary_light</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/primary</item>
    </style>
</resources>