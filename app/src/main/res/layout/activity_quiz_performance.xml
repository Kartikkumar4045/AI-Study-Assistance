<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_16"
    android:paddingTop="@dimen/space_20"
    android:paddingEnd="@dimen/space_16"
    android:paddingBottom="@dimen/space_12"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivQuizPerformanceBack"
            android:layout_width="@dimen/icon_size_m"
            android:layout_height="@dimen/icon_size_m"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Back"
            android:focusable="true"
            android:padding="2dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_main" />

        <TextView
            style="@style/TextAppearance.AIStudyAssistance.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:text="Quiz Performance"
            android:textSize="@dimen/text_subtitle" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        style="@style/Widget.AIStudyAssistance.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        app:cardBackgroundColor="@color/primary_light"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overview"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/tvPerfTotal"
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="Total Quizzes: 0"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPerfAverage"
                style="@style/TextAppearance.AIStudyAssistance.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="Average Score: 0" />

            <TextView
                android:id="@+id/tvPerfBest"
                style="@style/TextAppearance.AIStudyAssistance.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="Best Score: 0" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        style="@style/Widget.AIStudyAssistance.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/space_12">

            <Spinner
                android:id="@+id/spinnerTimeRange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Spinner
                android:id="@+id/spinnerTopicFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                android:layout_weight="1" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        style="@style/TextAppearance.AIStudyAssistance.Section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:text="Recent Attempts" />

    <TextView
        android:id="@+id/tvPerfEmpty"
        style="@style/TextAppearance.AIStudyAssistance.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:background="@color/primary_light"
        android:paddingHorizontal="@dimen/space_12"
        android:paddingVertical="@dimen/space_16"
        android:gravity="center"
        android:text="No quiz attempts for selected filters"
        android:textColor="@color/primary"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_8"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_20"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llQuizAttempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTakeAnotherQuiz"
        style="@style/Widget.AIStudyAssistance.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/space_12"
        android:text="Take another quiz" />

</LinearLayout>
