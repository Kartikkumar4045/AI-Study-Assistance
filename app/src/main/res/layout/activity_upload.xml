<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".ui.upload.UploadActivity">

    <!-- Standardized Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_main"
            app:title="@string/upload_title_study_materials"
            app:titleCentered="true"
            app:titleTextStyle="@style/TextAppearance.AIStudyAssistance.Title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/uploadScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <!-- UPLOAD OPTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Upload PDF Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUploadPdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_8"
                    app:cardCornerRadius="@dimen/radius_m"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_24"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="@dimen/icon_size_xl"
                            android:layout_height="@dimen/icon_size_xl"
                            android:contentDescription="@string/upload_cd_upload_pdf"
                            android:src="@android:drawable/ic_menu_save"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:text="@string/upload_action_pdf"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Upload Image Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUploadImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_8"
                    app:cardCornerRadius="@dimen/radius_m"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_24"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="@dimen/icon_size_xl"
                            android:layout_height="@dimen/icon_size_xl"
                            android:contentDescription="@string/upload_cd_upload_image"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/accent_orange" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:text="@string/upload_action_image"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_32"
                android:text="@string/upload_library_title" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardActiveUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:visibility="gone"
                app:cardBackgroundColor="@color/primary_light"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/tvActiveUploadTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upload_active_title"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProgressStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/upload_preparing"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:indeterminate="false"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/divider" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutSearch"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:hint="@string/upload_search_hint"
                app:boxBackgroundColor="@color/card_bg"
                app:boxCornerRadiusBottomEnd="@dimen/radius_m"
                app:boxCornerRadiusBottomStart="@dimen/radius_m"
                app:boxCornerRadiusTopEnd="@dimen/radius_m"
                app:boxCornerRadiusTopStart="@dimen/radius_m"
                app:endIconMode="clear_text"
                app:startIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/upload_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPdf"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_filter_pdfs" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipImages"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_filter_images" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_48"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:alpha="0.2"
                    android:contentDescription="@string/upload_cd_empty_state"
                    android:src="@android:drawable/ic_menu_agenda" />

                <TextView
                    android:id="@+id/tvEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/upload_empty_notes"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUploadFirst"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/upload_first_note"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- List of Notes -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_note_grid" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressLoadMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/divider" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>