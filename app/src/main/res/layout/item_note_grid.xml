<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/space_8"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="@dimen/space_12">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:shimmer_auto_start="true"
                app:shimmer_duration="900">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_thumbnail_placeholder" />
            </com.facebook.shimmer.ShimmerFrameLayout>

            <ImageView
                android:id="@+id/ivNoteThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/primary_light"
                android:contentDescription="@string/upload_note_thumbnail"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                tools:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvTypeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/space_8"
                android:background="@android:color/white"
                android:paddingStart="@dimen/space_8"
                android:paddingTop="@dimen/space_4"
                android:paddingEnd="@dimen/space_8"
                android:paddingBottom="@dimen/space_4"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold"
                tools:text="PDF" />

            <LinearLayout
                android:id="@+id/layoutDeletingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:indicatorColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/upload_deleting_inline"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tvNoteName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            tools:text="Operating Systems Unit 1.pdf" />

        <TextView
            android:id="@+id/tvNoteDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption"
            tools:text="Uploaded: Oct 24, 2023" />
    </LinearLayout>
</androidx.cardview.widget.CardView>


