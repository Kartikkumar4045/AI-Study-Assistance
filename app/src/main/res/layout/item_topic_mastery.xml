<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.AIStudyAssistance.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_12">

        <TextView
            android:id="@+id/tvMasteryTopicTitle"
            style="@style/TextAppearance.AIStudyAssistance.Section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Topic"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/tvMasteryTopicStats"
            style="@style/TextAppearance.AIStudyAssistance.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="Quiz 0 • Flashcards 0 • Chat 0" />

        <TextView
            android:id="@+id/tvMasteryTopicLast"
            style="@style/TextAppearance.AIStudyAssistance.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            android:text="Last active: Never"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMasteryPracticeQuiz"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Practice Quiz" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMasteryOpenFlashcards"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                android:layout_weight="1"
                android:text="Open Flashcards" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>


