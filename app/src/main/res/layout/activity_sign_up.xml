<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_32"
            android:layout_marginBottom="@dimen/space_32">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/graduationcap201"
                 />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:layout_gravity="center"
                android:text="Join AI Study Assistant"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="Master your subjects with AI"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_16"
            app:boxCornerRadiusBottomEnd="@dimen/radius_m"
            app:boxCornerRadiusBottomStart="@dimen/radius_m"
            app:boxCornerRadiusTopEnd="@dimen/radius_m"
            app:boxCornerRadiusTopStart="@dimen/radius_m"
            app:startIconDrawable="@drawable/email24"
            app:startIconTint="@color/primary"
            android:hint="Email Address">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvEmailVerificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_8"
            android:text="Email not verified"
            android:textColor="@color/red"
            android:textSize="@dimen/text_caption" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_16"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendEmailOtp"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1.4"
                android:layout_marginEnd="@dimen/space_8"
                android:text="Send Verification Email" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckEmailVerified"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:text="Check Verified" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_16"
            app:boxCornerRadiusBottomEnd="@dimen/radius_m"
            app:boxCornerRadiusBottomStart="@dimen/radius_m"
            app:boxCornerRadiusTopEnd="@dimen/radius_m"
            app:boxCornerRadiusTopStart="@dimen/radius_m"
            app:prefixText="+91 "
            app:prefixTextColor="@color/text_main"
            android:hint="Phone Number">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvPhoneVerificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_8"
            android:text="Phone not verified"
            android:textColor="@color/red"
            android:textSize="@dimen/text_caption" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_12"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendPhoneOtp"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1.4"
                android:layout_marginEnd="@dimen/space_8"
                android:text="Send Phone OTP" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResendPhoneOtp"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:text="Resend OTP" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPhoneOtpBlockedCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_12"
            android:textColor="@color/red"
            android:textSize="@dimen/text_caption"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhoneOtp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_12"
            app:boxCornerRadiusBottomEnd="@dimen/radius_m"
            app:boxCornerRadiusBottomStart="@dimen/radius_m"
            app:boxCornerRadiusTopEnd="@dimen/radius_m"
            app:boxCornerRadiusTopStart="@dimen/radius_m"
            android:hint="Enter Phone OTP">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhoneOtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerifyPhoneOtp"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/space_16"
            android:text="Verify Phone OTP" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditVerifiedContacts"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/space_16"
            android:text="Edit Email / Phone"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVerifiedContactsLockedHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:layout_marginBottom="@dimen/space_16"
            android:gravity="center"
            android:text="Email and phone are locked after verification. Tap Edit to change."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_16"
            app:boxCornerRadiusBottomEnd="@dimen/radius_m"
            app:boxCornerRadiusBottomStart="@dimen/radius_m"
            app:boxCornerRadiusTopEnd="@dimen/radius_m"
            app:boxCornerRadiusTopStart="@dimen/radius_m"
            app:startIconDrawable="@drawable/authorization30"
            app:startIconTint="@color/primary"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/icon_secondary"
            android:hint="Create Password">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCreatePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_24"
            app:boxCornerRadiusBottomEnd="@dimen/radius_m"
            app:boxCornerRadiusBottomStart="@dimen/radius_m"
            app:boxCornerRadiusTopEnd="@dimen/radius_m"
            app:boxCornerRadiusTopStart="@dimen/radius_m"
            app:startIconDrawable="@drawable/authorization30"
            app:startIconTint="@color/primary"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/icon_secondary"
            android:hint="Confirm Password">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignUp"
            style="@style/Widget.AIStudyAssistance.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Create Account" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_32"
            android:layout_marginBottom="@dimen/space_32"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/space_16"
                android:text="social signup"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_overline" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_8"
                android:text="Google"
                app:icon="@drawable/google36"
                app:iconTint="@null"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGithub"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:text="GitHub"
                app:icon="@drawable/github60"
                app:iconTint="@null"
                app:iconGravity="textStart" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_48"
            android:layout_marginBottom="@dimen/space_16"
            android:gravity="center"
            android:paddingTop="@dimen/space_32"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="@color/primary"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>