<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/space_24">

        <!-- Graduation Cap Icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="@dimen/space_24"
            android:src="@drawable/graduationcap201"
            android:contentDescription="Graduation Cap"
            app:tint="@color/primary" />

        <!-- Create an Account Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:text="Create an Account"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_main" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="Sign up to get started"
            android:textSize="15sp"
            android:textColor="@color/text_hint" />

        <!-- ===== Main Card ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            app:cardCornerRadius="@dimen/radius_m"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                    android:padding="@dimen/space_16">

                <!-- ======= Email Section ======= -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main" />

                <!-- Email Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/email24"
                        app:tint="@color/icon_secondary"
                        android:contentDescription="Email Icon" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Enter your email"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:paddingStart="10dp"
                        android:inputType="textEmailAddress"
                        android:maxLines="1" />
                </LinearLayout>

                <!-- ======= Phone Number Section ======= -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="Phone Number"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main" />

                <!-- Phone Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16">

                    <!-- India Flag -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="18dp"
                        android:src="@drawable/india48"
                        android:scaleType="fitCenter"
                        android:contentDescription="India Flag" />

                    <!-- Country Code -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+91"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:textStyle="bold"
                        android:paddingStart="6dp"
                        android:paddingEnd="8dp" />

                    <!-- Separator Line -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="@color/divider" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Enter your phone number"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:paddingStart="10dp"
                        android:inputType="phone"
                        android:maxLines="1" />
                </LinearLayout>

                <!-- ======= Password Section ======= -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="Password"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main" />

                <!-- Create Password Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="@dimen/space_8"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/authorization30"
                        app:tint="@color/icon_secondary"
                        android:contentDescription="Lock Icon" />

                    <EditText
                        android:id="@+id/etCreatePassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Create a password"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:paddingStart="10dp"
                        android:inputType="textPassword"
                        android:maxLines="1" />

                    <ImageView
                        android:id="@+id/ivTogglePassword1"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/visisbilityoff45"
                        app:tint="@color/icon_secondary"
                        android:contentDescription="Toggle Password" />
                </LinearLayout>

                <!-- Confirm Password Input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/authorization30"
                        app:tint="@color/icon_secondary"
                        android:contentDescription="Lock Icon" />

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Confirm your password"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:paddingStart="10dp"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        />

                    <ImageView
                        android:id="@+id/ivTogglePassword2"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/visisbilityoff45"
                        app:tint="@color/icon_secondary"
                        android:contentDescription="Toggle Password" />
                </LinearLayout>

                <!-- Sign Up Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignUp"
                    style="@style/Widget.AIStudyAssistance.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/space_24"
                    android:text="Sign Up" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ===== "Already have an account? Sign In" OUTSIDE CardView ===== -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <!-- Google Pill Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvGoogle"
                android:layout_width="100dp"
                android:layout_height="50dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/input_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/google96"
                        android:contentDescription="Google" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Separator Line -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/divider" />

            <!-- Github Pill Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvGithub"
                android:layout_width="100dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/input_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/github120"
                        android:contentDescription="Github" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <!-- ===== Bottom Social Icons Card ===== -->

        <View
            android:layout_width="1dp"
            android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>