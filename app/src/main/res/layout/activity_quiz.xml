<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_16"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/space_16"
            android:padding="@dimen/space_8"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:id="@+id/tvQuizTitle"
            style="@style/TextAppearance.AIStudyAssistance.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quiz: Binary Search"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvProgress"
        style="@style/TextAppearance.AIStudyAssistance.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_8"
        android:text="Question 1 / 5"
        android:textColor="@color/text_secondary" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="@dimen/space_24"
        android:progress="20"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/divider" />

    <TextView
        android:id="@+id/tvQuestion"
        style="@style/TextAppearance.AIStudyAssistance.Section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_16"
        android:lineSpacingExtra="4dp"
        android:text="What is the time complexity of binary search?" />

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <RadioButton
            android:id="@+id/rbOptionA"
            style="@style/TextAppearance.AIStudyAssistance.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_8"
            android:background="@drawable/radio_button_background"
            android:button="@null"
            android:padding="@dimen/space_16"
            android:text="A. O(n)" />

        <RadioButton
            android:id="@+id/rbOptionB"
            style="@style/TextAppearance.AIStudyAssistance.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_8"
            android:background="@drawable/radio_button_background"
            android:button="@null"
            android:padding="@dimen/space_16"
            android:text="B. O(log n)" />

        <RadioButton
            android:id="@+id/rbOptionC"
            style="@style/TextAppearance.AIStudyAssistance.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_8"
            android:background="@drawable/radio_button_background"
            android:button="@null"
            android:padding="@dimen/space_16"
            android:text="C. O(n log n)" />

        <RadioButton
            android:id="@+id/rbOptionD"
            style="@style/TextAppearance.AIStudyAssistance.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/radio_button_background"
            android:button="@null"
            android:padding="@dimen/space_16"
            android:text="D. O(n²)" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevious"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_8"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Previous" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            style="@style/Widget.AIStudyAssistance.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_8"
            android:layout_weight="1"
            android:text="Next" />
    </LinearLayout>

</LinearLayout>
