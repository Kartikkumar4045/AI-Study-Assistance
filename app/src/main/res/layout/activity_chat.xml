<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".ui.chat.ChatActivity">

    <!-- Standardized Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_bg"
        app:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/text_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="AI Study Assistant"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivChatMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/text_main" />

        </RelativeLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Study Mode Selector -->
    <HorizontalScrollView
        android:id="@+id/hsvStudyModes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/space_8"
        android:paddingHorizontal="@dimen/space_16"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:chipSpacingHorizontal="@dimen/space_8">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExplain"
                style="@style/Widget.AIStudyAssistance.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explain" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipShortNotesMode"
                style="@style/Widget.AIStudyAssistance.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short Notes" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExamAnswer"
                style="@style/Widget.AIStudyAssistance.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exam Answer" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipQuiz"
                style="@style/Widget.AIStudyAssistance.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFlashcards"
                style="@style/Widget.AIStudyAssistance.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flashcards" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Chat Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="@dimen/space_8"
        android:paddingBottom="@dimen/space_16"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/layoutAttachmentBanner"
        app:layout_constraintTop_toBottomOf="@id/hsvStudyModes"
        tools:listitem="@layout/item_chat_message" />

    <!-- Attachment Banner -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutAttachmentBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_16"
        android:layout_marginBottom="@dimen/space_8"
        app:cardBackgroundColor="@color/primary_light"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutInput">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/space_12">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/primary" />

            <TextView
                android:id="@+id/tvAttachmentInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:text="Using document: example.pdf"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivRemoveAttachment"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/primary" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Modern Chat Input Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_12"
        app:cardCornerRadius="@dimen/radius_l"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_8">

            <ImageButton
                android:id="@+id/btnAttach"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/primary" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Ask your study assistant..."
                android:maxLines="4"
                android:padding="@dimen/space_12"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                app:elevation="0dp"
                app:tint="@color/white"
                android:backgroundTint="@color/primary"
                android:src="@android:drawable/ic_menu_send" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>