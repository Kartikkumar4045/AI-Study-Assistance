<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/space_12">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFlashcard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_l"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_32">

            <TextView
                android:id="@+id/tvQuestionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_12"
                android:text="@string/flashcard_question_label"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_main"
                android:lineSpacingExtra="8dp"
                android:textSize="@dimen/text_title"
                android:textStyle="bold"
                tools:text="What is the time complexity of binary search?" />

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginTop="@dimen/space_24"
                android:background="@color/primary_light" />

            <TextView
                android:id="@+id/tvTapHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:text="@string/flashcard_tap_to_reveal"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/tvThinkPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:gravity="center"
                android:text="@string/flashcard_think_prompt"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShowAnswer"
                style="@style/Widget.AIStudyAssistance.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="@string/flashcard_show_answer"
                android:visibility="gone" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="220dp"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_section"
                    android:visibility="gone"
                    tools:text="O(log n) because the search space is halved in each step." />
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Rating actions shown after flip -->
    <LinearLayout
        android:id="@+id/layoutDifficulty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEasy"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_4"
            android:layout_weight="1"
            android:text="@string/flashcard_difficulty_easy"
            android:textColor="@color/ds_success"
            app:strokeColor="@color/ds_success" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMedium"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_4"
            android:layout_weight="1.2"
            android:text="@string/flashcard_difficulty_medium"
            android:textColor="@color/ds_warning"
            app:strokeColor="@color/ds_warning" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHard"
            style="@style/Widget.AIStudyAssistance.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_4"
            android:layout_weight="1"
            android:text="@string/flashcard_difficulty_hard"
            android:textColor="@color/ds_error"
            app:strokeColor="@color/ds_error" />
    </LinearLayout>

</LinearLayout>