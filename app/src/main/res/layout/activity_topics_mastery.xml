<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/space_20"
        android:paddingEnd="@dimen/space_16"
        android:paddingBottom="@dimen/space_16">

        <ImageView
            android:id="@+id/ivTopicsBack"
            android:layout_width="@dimen/icon_size_m"
            android:layout_height="@dimen/icon_size_m"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Back"
            android:focusable="true"
            android:padding="2dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_main" />

        <TextView
            style="@style/TextAppearance.AIStudyAssistance.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:layout_weight="1"
            android:text="Topics Mastery"
            android:textSize="@dimen/text_title" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/space_16"
        android:paddingEnd="@dimen/space_16"
        android:paddingBottom="@dimen/space_20">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                style="@style/Widget.AIStudyAssistance.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_16"
                app:cardBackgroundColor="@color/primary_light"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/tvTopicMasteryCount"
                        style="@style/TextAppearance.AIStudyAssistance.Section"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 unique topics"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_section" />

                    <TextView
                        style="@style/TextAppearance.AIStudyAssistance.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="Tracked from Chat, Quiz and Flashcards"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvTopicsEmpty"
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:background="@drawable/bg_input_field"
                android:drawablePadding="@dimen/space_8"
                android:drawableStart="@android:drawable/ic_dialog_info"
                android:gravity="center"
                android:paddingHorizontal="@dimen/space_20"
                android:paddingVertical="@dimen/space_24"
                android:text="No topics yet. Start with chat, quiz, or flashcards."
                android:textColor="@color/text_secondary"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/llTopicMastery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>