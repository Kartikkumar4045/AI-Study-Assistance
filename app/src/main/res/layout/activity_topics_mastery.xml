<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_16"
    android:paddingTop="@dimen/space_20"
    android:paddingEnd="@dimen/space_16"
    android:paddingBottom="@dimen/space_12"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivTopicsBack"
            android:layout_width="@dimen/icon_size_m"
            android:layout_height="@dimen/icon_size_m"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Back"
            android:focusable="true"
            android:padding="2dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_main" />

        <TextView
            style="@style/TextAppearance.AIStudyAssistance.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:text="Topics Mastery"
            android:textSize="@dimen/text_subtitle" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        style="@style/Widget.AIStudyAssistance.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        app:cardBackgroundColor="@color/primary_light"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_12">

            <TextView
                android:id="@+id/tvTopicMasteryCount"
                style="@style/TextAppearance.AIStudyAssistance.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 unique topics"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_body" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="Tracked from Chat, Quiz and Flashcards"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvTopicsEmpty"
        style="@style/TextAppearance.AIStudyAssistance.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_20"
        android:background="@color/primary_light"
        android:gravity="center"
        android:paddingHorizontal="@dimen/space_12"
        android:paddingVertical="@dimen/space_16"
        android:text="No topics yet. Start with chat, quiz, or flashcards."
        android:textColor="@color/primary"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_8"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/space_20">

        <LinearLayout
            android:id="@+id/llTopicMastery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>



