<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_main"
            app:title="@string/flashcard_setup_title"
            app:titleCentered="true"
            app:titleTextStyle="@style/TextAppearance.AIStudyAssistance.Title" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/flashcard_setup_source"
                android:layout_marginBottom="@dimen/space_16" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_24">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTopic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_8"
                    app:cardCornerRadius="@dimen/radius_m"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="@color/primary"
                            tools:ignore="ContentDescription"
                            android:layout_marginBottom="@dimen/space_8"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/flashcard_setup_by_topic"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_main" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMyNotes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_8"
                    app:cardCornerRadius="@dimen/radius_m"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/accent_purple"
                            tools:ignore="ContentDescription"
                            android:layout_marginBottom="@dimen/space_8"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/flashcard_setup_my_notes"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_main" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFlashcardTopic"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_24"
                app:boxCornerRadiusBottomEnd="@dimen/radius_m"
                app:boxCornerRadiusBottomStart="@dimen/radius_m"
                app:boxCornerRadiusTopEnd="@dimen/radius_m"
                app:boxCornerRadiusTopStart="@dimen/radius_m"
                android:hint="@string/flashcard_setup_enter_topic">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFlashcardTopic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <Spinner
                android:id="@+id/spinnerFlashcardNotes"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/space_8"
                android:visibility="gone"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="@dimen/space_16" />

            <TextView
                android:id="@+id/tvFlashcardSelectedNotePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/flashcard_setup_selected_note_placeholder"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/space_24"
                android:visibility="gone" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/flashcard_setup_deck_size"
                android:layout_marginBottom="@dimen/space_16" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_32"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/flashcard_setup_number_of_cards"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:id="@+id/tvFlashcardCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/flashcard_setup_card_count_initial"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderFlashcardCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="2.0"
                        android:valueTo="20.0"
                        android:stepSize="1.0"
                        android:value="10.0" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateFlashcards"
                style="@style/Widget.AIStudyAssistance.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/flashcard_setup_generate_deck"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconGravity="textStart" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>