<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_pill_button"
    android:backgroundTint="@color/card_bg"
    android:orientation="vertical"
    android:padding="@dimen/space_24">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/space_20"
        android:background="@color/divider" />

    <TextView
        style="@style/TextAppearance.AIStudyAssistance.Section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/upload_actions_title" />

    <TextView
        android:id="@+id/tvActionNoteName"
        style="@style/TextAppearance.AIStudyAssistance.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/upload_actions_default_note_label" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionViewFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_20"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/primary" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_view_file" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionSummarize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="@color/accent_purple" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_summarize" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionShortNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/accent_green" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_short_notes" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionQuiz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_help"
                app:tint="@color/primary" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_quiz" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionFlashcards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/accent_orange" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_flashcards" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActionDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="@dimen/icon_size_m"
                android:layout_height="@dimen/icon_size_m"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/red" />

            <TextView
                style="@style/TextAppearance.AIStudyAssistance.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:text="@string/upload_option_delete"
                android:textColor="@color/red" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>


