<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/graduationcap201"
        android:label="@string/app_name"
        android:roundIcon="@drawable/graduationcap201"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIStudyAssistance">

        <activity
            android:name=".ui.auth.SignUpActivity"
            android:exported="true" />

        <activity
            android:name=".ui.auth.SignInActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.home.MainActivity"
            android:exported="true" />

        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.upload.UploadActivity"
            android:exported="false" />

        <activity
            android:name=".ui.quiz.QuizSetupActivity"
            android:exported="false" />

        <activity
            android:name=".ui.quiz.QuizActivity"
            android:exported="false" />

        <activity
            android:name=".ui.quiz.QuizResultActivity"
            android:exported="false" />

        <activity
            android:name=".ui.flashcard.FlashcardSetupActivity"
            android:exported="false" />

        <activity
            android:name=".ui.flashcard.FlashcardActivity"
            android:exported="false" />

    </application>

</manifest>
