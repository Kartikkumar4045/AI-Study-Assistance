<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIStudyAssistance">

        <activity
            android:name=".Activity.SignUpActivity"
            android:exported="true" />

        <activity
            android:name=".Activity.SignInActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <activity
            android:name=".Activity.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Activity.UploadActivity"
            android:exported="false" />

        <activity
            android:name=".Activity.QuizSetupActivity"
            android:exported="false" />

        <activity
            android:name=".Activity.QuizActivity"
            android:exported="false" />

        <activity
            android:name=".Activity.QuizResultActivity"
            android:exported="false" />

        <activity
            android:name=".Activity.FlashcardSetupActivity"
            android:exported="false" />

        <activity
            android:name=".Activity.FlashcardActivity"
            android:exported="false" />

    </application>

</manifest>